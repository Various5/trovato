# Trovato — Environment Variables
# Copy this file to .env and adjust as needed. All paths are optional;
# defaults resolve to %APPDATA%/Trovato on Windows.
# (Env vars keep the historical LDI_ prefix for config-file compatibility.)

# --- Server ---
LDI_HOST=127.0.0.1
LDI_PORT=8765
# Set 1 to expose the app on the LAN (default 0 = localhost only)
LDI_ALLOW_LAN=0
# Secret used to sign session cookies. Auto-generated on first run if empty.
LDI_SECRET_KEY=

# --- LM Studio (OpenAI-compatible API) ---
LDI_LMSTUDIO_BASE_URL=http://localhost:1234/v1
LDI_LMSTUDIO_API_KEY=lm-studio
# Override default models (otherwise configured at runtime in Settings):
LDI_CHAT_MODEL=
LDI_VISION_MODEL=
LDI_EMBEDDING_MODEL=

# --- Storage paths (leave empty for OS-defaults) ---
LDI_DATA_DIR=
LDI_DB_URL=

# --- OCR ---
# Path to tesseract.exe on Windows (e.g. C:\Program Files\Tesseract-OCR\tesseract.exe)
LDI_TESSERACT_CMD=
LDI_OCR_LANG=eng+deu

# --- Logging ---
LDI_LOG_LEVEL=INFO
LDI_DEBUG=0
